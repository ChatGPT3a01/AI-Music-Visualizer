# ========================================
# Eye Music 環境變數配置範例
# ========================================
#
# 使用說明：
# 1. 複製此檔案為 .env
# 2. 填入你的實際 API Keys 和配置
# 3. 確保 .env 已加入 .gitignore（不要上傳到 Git）
#
# 作者：阿亮老師（曾慶良）
# 版本：1.0.0
# ========================================

# ----------------------------------------
# Flask 應用程式設定
# ----------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# ----------------------------------------
# AI API 設定
# ----------------------------------------

# Google AI Studio API (Gemini 2.5 Flash/Pro)
# 申請網址：https://makersuite.google.com/app/apikey
# 格式：AIzaSy... (以 AIzaSy 開頭)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# OpenAI API (GPT-5.5/GPT-5.5)
# 申請網址：https://platform.openai.com/api-keys
# 格式：sk-... (以 sk- 開頭)
# 注意：需要先儲值至少 $5 USD
OPENAI_API_KEY=your-openai-api-key-here

# ----------------------------------------
# FFmpeg 設定
# ----------------------------------------
# FFmpeg 路徑（選填，如果系統 PATH 中已有 FFmpeg 則不需要設定）
# Windows 範例：
# FFMPEG_BINARY=C:\ffmpeg\bin\ffmpeg.exe
# IMAGEIO_FFMPEG_EXE=C:\ffmpeg\bin\ffmpeg.exe
#
# macOS 範例：
# FFMPEG_BINARY=/usr/local/bin/ffmpeg
# IMAGEIO_FFMPEG_EXE=/usr/local/bin/ffmpeg

# ----------------------------------------
# 伺服器設定
# ----------------------------------------
HOST=0.0.0.0
PORT=5000

# ----------------------------------------
# 檔案上傳與輸出設定
# ----------------------------------------
# 上傳檔案大小限制（位元組，預設 500MB）
MAX_UPLOAD_SIZE=524288000
UPLOAD_FOLDER=src/static/uploads
OUTPUT_FOLDER=src/static/outputs

# 預設影片解析度
DEFAULT_RESOLUTION=1920x1080

# 預設 FPS
DEFAULT_FPS=30

# 預設視覺化類型（bars, circular, piano）
DEFAULT_VISUALIZATION_TYPE=circular

# 預設色彩方案（rainbow, fire, ocean, purple）
DEFAULT_COLOR_SCHEME=rainbow

# ----------------------------------------
# AI 模型偏好設定
# ----------------------------------------
# 預設音樂分析模型（gemini-flash, gemini-pro, gpt-5.5）
AI_MUSIC_ANALYSIS_MODEL=gemini-flash

# 預設描述生成模型（gpt-5.5, gpt-5.5）
AI_DESCRIPTION_MODEL=gpt-5.5

# 預設社群文案生成模型（gpt-5.5, gpt-5.5）
AI_SOCIAL_CONTENT_MODEL=gpt-5.5

# AI 請求逾時時間（秒）
AI_REQUEST_TIMEOUT=30

# AI 請求重試次數
AI_MAX_RETRIES=3

# ----------------------------------------
# 成本控制設定（選填）
# ----------------------------------------
# 每日 API 呼叫上限（0 = 無限制）
DAILY_API_LIMIT=1000

# 單一任務最大成本（USD）
MAX_COST_PER_TASK=0.5

# ----------------------------------------
# Google Sheets 整合設定（選填）
# ----------------------------------------
# 如果使用 Google Sheets API（非 GAS）時需要
# GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# ----------------------------------------
# 快取與效能設定（選填）
# ----------------------------------------
# Redis URL（如使用 Celery 非同步任務）
# REDIS_URL=redis://localhost:6379/0

# Celery Broker URL
# CELERY_BROKER_URL=redis://localhost:6379/0

# 快取過期時間（秒）
CACHE_TTL=3600

# ----------------------------------------
# 日誌設定（選填）
# ----------------------------------------
# 日誌級別（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 日誌檔案路徑
# LOG_FILE=logs/eye_music.log

# ----------------------------------------
# 安全性設定（選填）
# ----------------------------------------
# CORS 允許的來源（多個用逗號分隔）
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# 是否啟用 API Key 驗證（GAS 請求）
ENABLE_API_KEY_AUTH=False

# API Key（如啟用驗證）
# API_KEY=your-secure-api-key-here

# ----------------------------------------
# 開發者選項（選填）
# ----------------------------------------
# 是否啟用詳細除錯輸出
VERBOSE_DEBUG=False

# 是否保留暫存檔案（用於除錯）
KEEP_TEMP_FILES=False

# 測試模式（不實際呼叫 AI API，使用模擬資料）
TEST_MODE=False
